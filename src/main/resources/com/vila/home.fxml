<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vila.controller.HomeController"
            styleClass="root-pane">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="4" styleClass="navbar">
            <Text text="VILA" styleClass="nav-brand"/>
            <HBox spacing="0" style="-fx-padding: 0 0 0 24;">
                <Button text="Women" styleClass="nav-link" onAction="#onFilterWomen"/>
                <Button text="Men"   styleClass="nav-link" onAction="#onFilterMen"/>
                <Button text="New Arrivals" styleClass="nav-link" onAction="#onFilterAll"/>
                <Button text="Sale"  styleClass="nav-link-sale"/>
            </HBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search" styleClass="search-input" prefWidth="190"/>
            <Button text="Search" onAction="#onSearch" styleClass="btn-ghost"/>
            <Button fx:id="cartButton" text="Bag" onAction="#onCartClick" styleClass="btn-ghost"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="0">

                <!-- Hero -->
                <StackPane styleClass="hero-banner" minHeight="440">
                    <VBox alignment="CENTER" spacing="18">
                        <Text text="SPRING / SUMMER 2025" styleClass="hero-label"/>
                        <Text text="Built to Move" styleClass="hero-title"/>
                        <Text text="Technical gear for every workout." styleClass="hero-subtitle"/>
                        <HBox alignment="CENTER" spacing="14">
                            <Button text="SHOP NOW" styleClass="btn-primary" onAction="#onFilterAll"/>
                            <Button text="VIEW ALL" styleClass="btn-secondary" onAction="#onFilterAll"/>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- Products section -->
                <VBox spacing="0" styleClass="products-section">

                    <!-- Category filters -->
                    <HBox styleClass="filter-bar">
                        <Button fx:id="tabAll"      text="All"       styleClass="filter-tab-active" onAction="#onFilterAll"/>
                        <Button fx:id="tabBottoms"  text="Bottoms"   styleClass="filter-tab"        onAction="#onFilterBottoms"/>
                        <Button fx:id="tabTops"     text="Tops"      styleClass="filter-tab"        onAction="#onFilterTops"/>
                        <Button fx:id="tabHoodies"  text="Hoodies"   styleClass="filter-tab"        onAction="#onFilterHoodies"/>
                        <Button fx:id="tabJackets"  text="Jackets"   styleClass="filter-tab"        onAction="#onFilterJackets"/>
                    </HBox>

                    <!-- Product grid -->
                    <FlowPane fx:id="productGrid" hgap="20" vgap="28" styleClass="product-flow-grid"/>

                </VBox>

                <!-- Footer -->
                <VBox styleClass="site-footer">
                    <HBox spacing="0" styleClass="footer-inner">

                        <!-- Brand column -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Text text="VILA" styleClass="footer-brand"/>
                            <Text text="Monterey, California" styleClass="footer-sub"/>
                            <Text text="Movement for every body." styleClass="footer-tagline"/>
                        </VBox>

                        <!-- Contact column -->
                        <VBox spacing="8" minWidth="220">
                            <Text text="CONTACT" styleClass="footer-heading"/>
                            <Text text="580 Pacific Grove Ave, Suite 100" styleClass="footer-text"/>
                            <Text text="Monterey, CA 93940" styleClass="footer-text"/>
                            <Text text="(831) 649-0241" styleClass="footer-text"/>
                            <Text text="hello@vilaactivewear.com" styleClass="footer-text"/>
                        </VBox>

                        <!-- Hours column -->
                        <VBox spacing="8" minWidth="200">
                            <Text text="HOURS" styleClass="footer-heading"/>
                            <Text text="Mon – Fri  10am – 7pm" styleClass="footer-text"/>
                            <Text text="Saturday   10am – 6pm" styleClass="footer-text"/>
                            <Text text="Sunday     11am – 5pm" styleClass="footer-text"/>
                        </VBox>

                        <!-- Info column -->
                        <VBox spacing="8" minWidth="200">
                            <Text text="INFO" styleClass="footer-heading"/>
                            <Text text="Free shipping over $100" styleClass="footer-text"/>
                            <Text text="Easy 30-day returns" styleClass="footer-text"/>
                            <Text text="Size guide" styleClass="footer-text"/>
                            <Text text="Care instructions" styleClass="footer-text"/>
                        </VBox>

                    </HBox>

                    <Separator styleClass="footer-divider"/>

                    <HBox alignment="CENTER_LEFT" styleClass="footer-bottom">
                        <Text text="© 2025 Vila Activewear  ·  All rights reserved." styleClass="footer-copy"/>
                    </HBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
